{
  "name": "inheribase",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.5.2+sha512.da9dc28cd3ff40d0592188235ab25d3202add8a207afbedc682220e4a0029ffbff4562102b9e6e46b4e3f9e8bd53e6d05de48544b0c57d4b0179e22c76d1199b",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/dashboard",
    "apps/marketing",
    "apps/docs",
    "apps/status",
    "apps/playground",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "bash scripts/vercel-build.sh",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "dev:marketing": "turbo dev --filter=@inheribase/marketing",
    "dev:dashboard": "turbo dev --filter=@inheribase/dashboard --filter=@inheribase/ui",
    "dev:status": "turbo dev --filter=@inheribase/status",
    "dev:playground": "turbo dev --filter=@inheribase/playground",
    "dev:docs": "turbo dev --filter=@inheribase/docs",
    "build:marketing": "FILTER=@inheribase/marketing FOLDER=apps/marketing bash scripts/vercel-build.sh",
    "build:dashboard": "FILTER=@inheribase/dashboard FOLDER=apps/dashboard bash scripts/vercel-build.sh",
    "build:status": "FILTER=@inheribase/status FOLDER=apps/status bash scripts/vercel-build.sh",
    "build:playground": "FILTER=@inheribase/playground FOLDER=apps/playground bash scripts/vercel-build.sh",
    "build:docs": "FILTER=@inheribase/docs FOLDER=apps/docs bash scripts/vercel-build.sh",
    "format": "prettier --write .",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel",
    "daemon": "npx tsx scripts/orchestrator-daemon.ts",
    "daemon:quiet": "npx tsx scripts/orchestrator-daemon.ts --quiet",
    "cron:fixed-date": "npx tsx scripts/cron/fixed-date-release.ts",
    "cron:dms": "npx tsx scripts/cron/dms-auto-release.ts",
    "cron:finalize": "npx tsx scripts/cron/finalize-releases.ts",
    "cron:credits": "npx tsx scripts/cron/credit-health-monitor.ts",
    "cron:all": "npx tsx scripts/cron/runner.ts --job=all",
    "cron:dry-run": "CRON_DRY_RUN=true npx tsx scripts/cron/runner.ts --job=all",
    "fix:conversations": "python3 scripts/rebuild_conversations.py",
    "verify:all": "pnpm typecheck && pnpm lint && pnpm test",
    "verify:infra": "npx tsx scripts/verify-db-connection.ts && npx tsx scripts/verify-kms.ts",
    "audit:contracts": "cd contract && forge test",
    "env:check": "npx tsx scripts/diagnose_supabase.ts"
  },
  "dependencies": {
    "@irys/sdk": "^0.2.11",
    "@supabase/supabase-js": "^2.89.0",
    "africastalking": "^0.7.8",
    "tsx": "^4.21.0",
    "turbo": "^2.7.3",
    "viem": "^2.46.3",
    "vite-plugin-node-polyfills": "^0.25.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/ui": "^4.0.16",
    "autoprefixer": "^10.4.0",
    "dotenv": "^17.2.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.6",
    "happy-dom": "^20.0.10",
    "jsdom": "^27.2.0",
    "next": "^15.4.10",
    "node-fetch": "^2.7.0",
    "postcss": "^8.4.0",
    "prettier": "^3.2.0",
    "prettier-plugin-solidity": "^1.4.1",
    "prettier-plugin-tailwindcss": "^0.5.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "pnpm": {
    "overrides": {
      "cross-spawn@<7.0.5": "^7.0.6",
      "undici@<6.19.2": "^6.21.1",
      "ws@<8.17.1": "^8.18.3",
      "braces@<3.0.3": "^3.0.3",
      "qs@<6.13.1": "^6.14.0",
      "cookie@<0.7.1": "^0.7.2",
      "body-parser@<1.20.3": "^1.20.3",
      "next@<15.2.3": "^15.4.10",
      "micromatch@<4.0.8": "^4.0.8",
      "nanoid@<3.3.8": "^3.3.8",
      "prosemirror-model": "1.25.4",
      "sharp": "0.34.5"
    }
  }
}
